<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <NeutralLanguage>en-US</NeutralLanguage>
    <Description>Largest C# stock indicator library with over 750 to choose from and easiest to use with abilities such as making an indicator out of any other indicator or using any moving average with any indicator. </Description>
    <Version>1.1.0</Version>
    <Authors>ooples</Authors>
    <Company></Company>
    <RepositoryUrl>https://github.com/ooples/PortfolioManager.StockIndicators</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageReleaseNotes>https://github.com/ooples/PortfolioManager.StockIndicators/releases</PackageReleaseNotes>
    <PackageProjectUrl>https://github.com/ooples/PortfolioManager.StockIndicators</PackageProjectUrl>
    <PackageTags>stock; stocks; technical; indicators; market; markets; analysis; library; finance; financial; indicator; moving average; algorithm; algorithms; trading; trades; algorithmic; ai; trade; indicators; technical indicators; technical analysis; stock indicators; crypto; bitcoin, cryptocurrency; forex; adaptive; kaufman; rsi; simple; weighted; exponential; moving; average; equity; strategy; chart; charting; mfi; cmf; relative; strength; index; volume; open; high; low; close; typical price; stochastic; adx; directional; reverse; trailing stop; pivot points; pivot; points; ultimate; ulcer; correlation; slope; cycle; standard; macd; schaff; ehlers; john ehlers; package; library; .net; c#; obv; nvi; pvi; beta; standard; deviation; bull; bear; smoothed; smooth; smoothing; chandelier; exit; atr; aroon; bollinger; bollinger bands; bands; price channels; hilbert; transform; chaikin; wilder; welles wilder; williams; larry williams; money; flow; parabolic; donchian; keltner; channel; alligator; gator; supertrend; fractal; chaos; oscillators; choppiness</PackageTags>
    <Copyright></Copyright>
    <PackageIcon>Favicon.jpg</PackageIcon>
    <AutoGenerateBindingRedirects>True</AutoGenerateBindingRedirects>
    <UseWindowsForms>False</UseWindowsForms>
    <UseWPF>False</UseWPF>
    <GenerateDocumentationFile>False</GenerateDocumentationFile>
    <SignAssembly>True</SignAssembly>
    <Title>Finance Stock Indicators</Title>
    <PackageReadmeFile></PackageReadmeFile>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <CheckForOverflowUnderflow>True</CheckForOverflowUnderflow>
    <Optimize>False</Optimize>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <CheckForOverflowUnderflow>True</CheckForOverflowUnderflow>
    <Optimize>True</Optimize>
  </PropertyGroup>


  <ItemGroup>
    <Compile Remove="bin\**" />
    <EmbeddedResource Remove="bin\**" />
    <None Remove="bin\**" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Example.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MathNet.Numerics" Version="5.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include="Images\Favicon.jpg">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\LinqOptimizer\src\LinqOptimizer.CSharp\LinqOptimizer.CSharp.csproj" />
  </ItemGroup>
</Project>
